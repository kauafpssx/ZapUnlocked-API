# API Authentication Key (MANDATORY)
API_KEY=SUA_SENHA_SECRETA_AQUI

# Server Port (Default: 8300)
PORT=8300

# Authentication Directory (Where session data is stored)
# Defaults to "auth" in the project root
AUTH_DIR=auth

# Internal Secret for Button Webhooks (Stateless encryption)
# Should be a long random string
INTERNAL_SECRET=mudar_para_uma_senha_longa_e_segura