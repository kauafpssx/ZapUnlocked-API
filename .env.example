# ============================================================
# ZapUnlocked API — Environment Variables
# Copy to .env and fill in the values.
# Run scripts/generate-env/generate-env.sh to auto-generate secrets.
# ============================================================

# ── Authentication (REQUIRED) ─────────────────────────────
# API key required on every request (header x-api-key or query ?API_KEY=)
API_KEY=

# Internal HMAC secret for button callback tokens
INTERNAL_SECRET=

# ── Server ────────────────────────────────────────────────
PORT=8300

# Public base URL used to build the /qr dashboard link in logs.
# Leave empty to auto-detect (uses $USER on Alwaysdata, hostname elsewhere).
# Example: https://myapp.example.com
PUBLIC_URL=

# Timezone for timestamps returned by send endpoints (messageId, timestamp fields).
# Uses IANA timezone names. Defaults to UTC.
# Examples: America/Sao_Paulo, America/New_York, Europe/London, Asia/Tokyo
TZ=UTC

# Dry run mode — intercepts all send endpoints and returns fake response without calling WhatsApp.
# Useful for integration testing and local development. Set to true to enable.
# DRY_RUN=false

# ── Storage (optional — defaults shown) ───────────────────
# AUTH_DIR=auth    # WhatsApp session SQLite file
# DATA_DIR=data    # Chat history, webhooks, settings

# Allowed CORS origins (comma-separated). Defaults to * (all origins).
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=*

# ── Feature flags ─────────────────────────────────────────
# Set to 0 to disable (useful for testing without WhatsApp)
ENABLE_WHATSAPP=1
ENABLE_FFMPEG_WARMUP=1

# ── Media upload limits ────────────────────────────────────
# Maximum allowed upload size in MB for multipart file uploads.
# Defaults to 500 MB.
# MAX_UPLOAD_SIZE_MB=500

# ── Media cleanup ──────────────────────────────────────────
# Automatic cleanup of temp_media/ folder.
# Files older than CLEANUP_MAX_AGE_DAYS OR total size exceeds CLEANUP_MAX_SIZE_MB
# will be removed (whichever threshold is hit first).
CLEANUP_MAX_AGE_DAYS=7
CLEANUP_MAX_SIZE_MB=500

# ── Log cleanup ────────────────────────────────────────────
# Automatic compression and cleanup of log files.
# Logs from previous days are compressed to .gz.
# Compressed logs older than LOG_MAX_AGE_DAYS OR total log size exceeds
# LOG_MAX_SIZE_MB will be deleted.
LOG_MAX_AGE_DAYS=30
LOG_MAX_SIZE_MB=50

# ── Meta AI ────────────────────────────────────────────────
# Override the Meta AI phone number (auto-detected by default based on account type).
# Personal account: 867051314767696@bot
# Business account: 718584497008509@bot
# Legacy format also accepted: 13135550002@s.whatsapp.net
# META_AI_PHONE=

# Timeout in seconds to wait for Meta AI response. Defaults to 30.
# META_AI_TIMEOUT=30

# If true, saves Meta AI generated images to disk and returns an /media/ URL.
# Only effective on non-Alwaysdata environments (Alwaysdata always discards).
# META_AI_KEEP_IMAGES=false

# ── Alwaysdata ─────────────────────────────────────────────
# Set if running on Alwaysdata shared hosting. Auto-detected in most cases.
# ALWAYSDATA_ACCOUNT=myaccount
